# Copy to .env at repo root and fill in.
# .env is gitignored. Never commit secrets.

# ===== LLM =====
# Switch between providers without code changes.
LLM_PROVIDER=anthropic            # anthropic | bedrock | qwen
LLM_MODEL=claude-sonnet-4-6       # provider-specific model id

# Anthropic (used in dev for speed)
ANTHROPIC_API_KEY=sk-ant-...

# AWS Bedrock (used in demo for multi-cloud story)
AWS_REGION=ap-southeast-5
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Alibaba Cloud Qwen (DashScope) — drives the orchestrator if LLM_PROVIDER=qwen,
# AND drives the browser-agent's mode=agent runs whenever DASHSCOPE_API_KEY is
# set. browser-agent prefers Qwen over Anthropic when both keys are present.
DASHSCOPE_API_KEY=sk-...
QWEN_MODEL=qwen-vl-max            # vision-language model used by browser-use
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Override only if you want browser-agent's agent mode to use a different
# Anthropic model than the orchestrator's LLM_MODEL above.
BROWSER_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== Alibaba OSS (screenshot artifact storage) =====
OSS_REGION=oss-ap-southeast-3
OSS_BUCKET=tng-rise-screenshots
OSS_ACCESS_KEY_ID=LTAI...
OSS_ACCESS_KEY_SECRET=...
OSS_ENDPOINT=https://oss-ap-southeast-3.aliyuncs.com

# ===== Service URLs (used by orchestrator) =====
MOCK_TNG_URL=http://localhost:5050
BROWSER_AGENT_URL=http://localhost:5001

# ===== Frontend =====
VITE_ORCHESTRATOR_URL=http://localhost:4000

# Public URL of the orchestrator on AWS, surfaced after `infra/aws/README.md`
# bootstrap. The frontend build sets VITE_ORCHESTRATOR_URL to this value when
# we ship to Alibaba OSS+CDN in the next phase.
ORCHESTRATOR_PUBLIC_URL=https://api.example.com

# ===== Misc =====
NODE_ENV=development
LOG_LEVEL=info
